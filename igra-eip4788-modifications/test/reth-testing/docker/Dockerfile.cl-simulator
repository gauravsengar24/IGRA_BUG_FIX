FROM node:18-alpine

# Install curl for healthcheck (if needed)
RUN apk add --no-cache curl

# Set working directory
WORKDIR /app

# Copy package.json if we need any dependencies
# For now, we only use built-in Node.js modules
# COPY package.json ./
# RUN npm install

# Copy the simulator sources
# Build context is reth-testing directory (from docker-compose.yml context: ..)
COPY cl-simulator /app/cl-simulator

# Make entrypoint executable
RUN chmod +x /app/cl-simulator/main.js

# Default command
CMD ["node", "/app/cl-simulator/main.js"]
