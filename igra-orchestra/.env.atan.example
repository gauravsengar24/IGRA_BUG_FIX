# ATAN-Only Mode Configuration
# Runs kaspad saving finality periods without the full IGRA stack
# Usage: docker compose -f docker-compose.atan.yml up -d
# With uploader: docker compose -f docker-compose.atan.yml --profile atan-uploader up -d

# --- Docker Configuration ---
LOGGING_DRIVER=json-file
SERVICE_RESTART_POLICY=unless-stopped

# --- Network ---
NETWORK=mainnet

# --- Kaspad Ports ---
KASPAD_GRPC_PORT=16110
KASPAD_P2P_PORT=16111
KASPAD_BORSH_PORT=17110
KASPAD_JSON_PORT=18110

# --- ATAN Configuration ---
# TX_ID_PREFIX is the legacy pre-KIP21 transaction ID prefix; kaspad uses it
# for ATAN filtering and as the ATAN import namespace (the network-specific
# CDN path segment in the auto-constructed import URL).
TX_ID_PREFIX=97b1
# Post-KIP21 dedicated IGRA lane namespace (4 bytes / 8 lowercase hex chars,
# no 0x prefix). kaspad receives --igra-lane-id=$IGRA_LANE_ID; the ATAN import
# URL uses the network-specific TX_ID_PREFIX, not this lane.
IGRA_LANE_ID=97b10000
CDN_BASE_URL=https://dyehoijgeqfp8.cloudfront.net
# Override the auto-constructed import URL
# ({CDN_BASE_URL}/{NETWORK}/{TX_ID_PREFIX}/index.pb). For Galleon testnet-10
# (NETWORK=testnet-10, TX_ID_PREFIX=97b4) this resolves to
# /testnet-10/97b4/index.pb; leave unset to use it.
# ATAN_IMPORT_URL=
# Optional: connect to a specific peer
# KASPAD_ADD_PEER=
# Optional: prune block data older than N days (omit to keep kaspad's default retention).
# KASPAD_RETENTION_PERIOD_DAYS=

# --- Image Versions ---
KASPAD_VERSION=2.3
ATAN_UPLOADER_VERSION=2.1

# --- ATAN Uploader (optional, use with --profile atan-uploader) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=atan-import
# DATADIR=/app/data/kaspa-mainnet/datadir
# DATADIR=/app/data/kaspa-testnet-10/datadir
# UPLOAD_JITTER_MAX_SECONDS=60
