# Docker image versions for Devnet deployments.
#
# The four core services are built from source (see scripts/setup-devnet.sh). The
# :devnet tags name the locally-built images so they never clobber pulled tags.
KASPAD_VERSION=devnet
RETH_VERSION=devnet
KASWALLET_VERSION=devnet
RPC_PROVIDER_VERSION=devnet

# Unused by the devnet compose, but validate_required_image_versions requires them.
NODE_HEALTH_CHECK_VERSION=devnet
ATAN_UPLOADER_VERSION=devnet
