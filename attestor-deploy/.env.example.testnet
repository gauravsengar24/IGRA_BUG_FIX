# Igra Attestor - Galleon Testnet Configuration
#
# Prerequisites:
#   - igra-orchestra must be running with the backend and frontend-w1 profiles
#   - The attestor connects to the RPC service via Traefik's load-balanced endpoint
#
# Setup:
#   1. Run: ./setup.sh testnet
#   2. Follow the prompts to enter your private key

# --- Network ---
# Must match the NETWORK value in your igra-orchestra .env
NETWORK=testnet

# --- Attestor ---
ATTESTOR_VERSION=2.3.2
CONTRACT_ADDRESS=0xc24Df70E408739aeF6bF594fd41db4632dF49188
CHAIN_ID=38836

# --- Logging ---
RUST_LOG=igra_attestation=info

# --- RPC ---
# Traefik RPC endpoint from your igra-orchestra setup.
# Find your domain in igra-orchestra's .env (IGRA_ORCHESTRA_DOMAIN).
# Example: RPC_URL=https://your-domain.com:8545
# This will be prompted during setup if not set.

# --- Optional ---
# HEALTH_PORT=8180
# METRICS_PORT=9190
# REORG_SAFETY_BLOCKS=30

# --- Delegated Attestation (optional) ---
# To run in delegated mode, set ALL THREE variables below.
# If none are set, the attester runs in direct mode (default).
#
# Generate the delegation signature on the controller's machine:
#   docker run --rm -it igranetwork/attestor:2.3.1 --sign-delegation
#
# CONTROLLER_ADDRESS=0x...          # Controller (cold wallet) address
# DELEGATION_EXPIRY=999999999       # Block number when delegation expires
# DELEGATION_SIGNATURE=0x...        # Controller's EIP-712 signature (65 bytes hex)
